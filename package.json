    "@ledgerhq/device-management-kit": "latest",
    "@ledgerhq/device-signer-kit-ethereum": "latest",
    "@ledgerhq/device-transport-kit-speculos": "latest",
    "dotenv": "latest",
    "rxjs": "latest",
    "viem": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
