# Required for LLM intent parsing. If omitted, the CLI falls back to deterministic parsing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Speculos exposes its automation API on port 5000.
SPECULOS_URL=http://localhost:5000

# RPC endpoint for read-only balance/history and unsigned tx assembly.
RPC_URL=

# Chain metadata for viem. Sepolia is the default demo chain.
CHAIN_ID=11155111
CHAIN_NAME=sepolia

# Read-only commands use this address and never touch the Ledger signer.
WATCH_ADDRESS=

# Optional Ledger Clear Signing partner token. Without it, ETH signing can degrade to blind signing.
LEDGER_ORIGIN_TOKEN=
