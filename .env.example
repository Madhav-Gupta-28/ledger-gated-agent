# Free from Google AI Studio: https://aistudio.google.com/apikey
# If omitted, the CLI falls back to a deterministic keyword parser.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Speculos exposes its automation API on port 5000.
SPECULOS_URL=http://localhost:5000

# RPC endpoint for read-only balance/history and unsigned tx assembly.
# Public free Sepolia endpoint — replace with Alchemy/Infura for reliability.
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Chain metadata for viem. Sepolia is the default demo chain.
CHAIN_ID=11155111
CHAIN_NAME=sepolia

# Read-only commands use this address and never touch the Ledger signer.
# Run: pnpm dev -- address   (with Speculos running) to get your Ledger address.
WATCH_ADDRESS=

# Optional Ledger Clear Signing partner token. Without it, ETH signing can degrade to blind signing.
LEDGER_ORIGIN_TOKEN=
